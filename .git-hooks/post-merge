# post-merge
#
# Automatically installs dependencies when lock files change after a merge.
#
# Usage:
#   .git-hooks/post-merge
#
# Exit codes:
#   0  Always.

[ -n "${GIT_HOOKS_SKIP:-}" ] && exit 0

# CHANGED_FILES stores the list of files changed in the merge.
CHANGED_FILES=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD 2>/dev/null)

# Check if uv.lock changed after merge
if echo "$CHANGED_FILES" | grep -q "uv\.lock$"; then
    if command -v uv >/dev/null 2>&1; then
        echo "📦 uv.lock changed after merge — running uv sync..."
        uv sync 2>/dev/null || true
        echo "✅ Python dependencies synced"
    else
        echo "⚠️  uv not found — run 'uv sync' manually"
    fi
fi

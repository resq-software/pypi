#
# Example environment configuration for ResQ MCP Server
# Python service using pydantic-settings (RESQ_ prefix)
# Copy this file to .env and update with your actual values

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────

# [optional] Display name for the MCP server
RESQ_PROJECT_NAME=resQ MCP Server

# [optional] Server version string
RESQ_VERSION=0.1.0

# [optional] Enable debug logging
RESQ_DEBUG=false

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────

# [required] Bearer token for mock authentication
# Generate a secure token: python -c "import secrets; print(secrets.token_urlsafe(32))"
RESQ_API_KEY=resq-dev-token

# ─────────────────────────────────────────────
# Deployment
# ─────────────────────────────────────────────

# [optional] Port for SSE server
RESQ_PORT=8000

# [optional] Host to bind to
RESQ_HOST=0.0.0.0

# ─────────────────────────────────────────────
# Safety & Features
# ─────────────────────────────────────────────

# [optional] If true, side-effecting tools are disabled or mocked safely
# Set to false in production with proper auth controls
RESQ_SAFE_MODE=true
